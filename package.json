{
  "name": "porkbun-mcp",
  "version": "0.1.0",
  "description": "MCP server for managing Porkbun domains, DNS records, nameservers, and URL forwarding over stdio.",
  "bin": {
    "porkbun-mcp": "dist/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "WHITEPAPER.md",
    "LICENSE"
  ],
  "directories": {
    "test": "tests"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/nidamen/porkbun-mcp.git"
  },
  "homepage": "https://github.com/nidamen/porkbun-mcp#readme",
  "bugs": {
    "url": "https://github.com/nidamen/porkbun-mcp/issues"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/index.ts",
    "start": "node dist/index.js",
    "smoke": "tsx scripts/smoke.ts",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "porkbun",
    "dns",
    "domains",
    "nameservers",
    "url-forwarding",
    "registrar"
  ],
  "author": "nidamen",
  "license": "MIT",
  "type": "module",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^25.9.2",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "vitest": "^4.1.8"
  }
}
